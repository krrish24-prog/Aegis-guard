{
  "name": "github-deploy-ap",
  "private": true,
  "version": "0.0.0",
  "type": "module",
  "scripts": {
    "dev": "tsx server.ts",
    "build": "node scripts/write-build-version.mjs && vite build && esbuild server.ts --bundle --platform=node --format=cjs --packages=external --sourcemap --outfile=dist-server/server.cjs",
    "preview": "vite preview",
    "start": "node dist-server/server.cjs",
    "clean": "node -e \"for (const dir of ['dist', 'dist-server']) require('fs').rmSync(dir, { recursive: true, force: true })\"",
    "lint": "tsc --noEmit",
    "test:rules": "firebase emulators:exec --only firestore --project aegis-rules-test \"npx jest tests/firestore.rules.test.ts\"",
    "test:rules:inner": "npx jest tests/firestore.rules.test.ts"
  },
  "dependencies": {
    "@google/genai": "^1.29.0",
    "clsx": "^2.1.1",
    "cors": "^2.8.6",
    "crypto-js": "^4.2.0",
    "date-fns": "^4.1.0",
    "dotenv": "^17.2.3",
    "emoji-picker-react": "^4.19.1",
    "express": "^4.21.2",
    "express-rate-limit": "^8.6.0",
    "firebase": "^12.11.0",
    "firebase-admin": "^12.0.0",
    "helmet": "^8.3.0",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "openai": "^6.32.0",
    "pdfjs-dist": "^5.4.624",
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "tailwind-merge": "^3.5.0"
  },
  "devDependencies": {
    "@firebase/rules-unit-testing": "^5.0.1",
    "@tailwindcss/vite": "^4.1.14",
    "@types/express": "^4.17.21",
    "@types/jest": "^29.5.14",
    "@types/node": "^22.14.0",
    "@vitejs/plugin-react": "^5.2.0",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.28.0",
    "firebase-tools": "^13.0.0",
    "jest": "^29.7.0",
    "tailwindcss": "^4.1.14",
    "ts-jest": "^29.2.5",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.0"
  }
}
